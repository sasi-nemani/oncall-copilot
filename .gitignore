# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Secrets / local config
.env
.env.*
!.env.example

# Runtime run logs (trace.py) + per-run eval reports (run_evals)
logs/*.jsonl
logs/*.json

# Generated data — regenerate from scripts/generate_corpus.py + src/ingest.py, don't commit.
# (README kept for reviewers; the data itself is not a git artifact.)
corpus/structured/
corpus/unstructured/
index/

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Vertex Vector Search — ephemeral resource state + large local vectors (rebuilt from corpus)
index/vertex_datapoints.jsonl
index/vertex_resources.json
index/vertex_meta.json

# ANN experiment datasets — large local vectors/datapoints, durably stored in GCS
datasets/

# Claude Code local session data
.claude/

# ADK local runtime (sessions db, etc.)
.adk/
adk_agent/.adk/
