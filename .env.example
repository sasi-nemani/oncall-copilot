# On-Call Copilot — example environment.
# Copy to .env (gitignored) and fill in a key, OR just `export` these in your shell.
# Only ONE provider key is strictly required. Everything else has sensible defaults.

# ── Answering backend ────────────────────────────────────────────────
# Which provider answers questions: openrouter | anthropic | openai
PROVIDER=openrouter

# Provide the key for the provider you chose above (uncomment one):
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Answering model per provider (the AGENT needs a tool-capable model):
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o

# ── Judge / verifier (evals + multi-agent verifier) ──────────────────
# Use a model DIFFERENT from the answerer so it isn't grading its own work.
# Default below is independent when you answer on OpenRouter/OpenAI.
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-sonnet-4-5
#
# SINGLE-KEY (OpenRouter only) — point the judge at a DIFFERENT OpenRouter model:
# JUDGE_PROVIDER=openrouter
# JUDGE_MODEL=qwen/qwen-2.5-72b-instruct      # must differ from OPENROUTER_MODEL

# ── Agent topology ───────────────────────────────────────────────────
# single = one investigator agent (default; the product path + eval baseline)
# multi  = governed pipeline: triage -> investigate -> verify -> postmortem
ONCALL_MODE=single

# ── Misc (optional) ──────────────────────────────────────────────────
# GUARDRAILS_FILE=guardrails.json   # path to the guardrail policy
# ONCALL_LOG_DIR=logs               # where per-run JSONL traces are written
# VIZ_PORT=8000                     # live visualizer port
