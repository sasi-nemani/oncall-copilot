# On-Call Copilot — example environment.
# Copy to .env (gitignored) and fill in a key, OR just `export` these in your shell.
# Only ONE provider key is strictly required. Everything else has sensible defaults.

# ── Answering backend ────────────────────────────────────────────────
# Which provider answers questions: openrouter | anthropic | openai
PROVIDER=openrouter

# Provide the key for the provider you chose above (uncomment one):
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Answering model per provider (the AGENT needs a tool-capable model):
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o

# ── Judge / verifier (evals + multi-agent verifier) ──────────────────
# Use a model DIFFERENT from the answerer so it isn't grading its own work.
# Default is ALL-OPENROUTER (no second key/cost): judge = a different OpenRouter model.
JUDGE_PROVIDER=openrouter
JUDGE_MODEL=google/gemma-4-31b-it:free        # must differ from OPENROUTER_MODEL
#   (verified working; alt: qwen/qwen3-next-80b-a3b-instruct:free)
#   NOTE: ':free' models are rate-limited — fine for demos, may 429 during a full 15-case
#   eval. The client retries 429s; for reliable/steadier runs add credits or use a paid model.
#
# Want a stronger judge and have an Anthropic key? Then instead:
# JUDGE_PROVIDER=anthropic
# JUDGE_MODEL=claude-sonnet-4-5

# ── Agent topology ───────────────────────────────────────────────────
# single = one investigator agent (default; the product path + eval baseline)
# multi  = governed pipeline: triage -> investigate -> verify -> postmortem
ONCALL_MODE=single

# ── Per-role models (optional) ───────────────────────────────────────
# Each agent role can use a different model. Defaults live in models.json; override any
# role here with MODEL_<ROLE> (+ optional PROVIDER_<ROLE>). Roles:
#   INVESTIGATOR (answers; MUST be tool-capable) · TRIAGE · VERIFIER · POSTMORTEM · JUDGE
# MODEL_INVESTIGATOR=meta-llama/llama-3.3-70b-instruct
# MODEL_TRIAGE=google/gemma-4-31b-it:free
# MODEL_VERIFIER=google/gemma-4-31b-it:free       # ≠ investigator -> independent verification
# MODEL_POSTMORTEM=meta-llama/llama-3.3-70b-instruct
# MODEL_JUDGE=google/gemma-4-31b-it:free           # for the eval loop, a paid model is steadier
# NOTE: OpenRouter free tier = 50 requests/DAY (then 429). Add $10 credits -> 1000/day.

# ── Misc (optional) ──────────────────────────────────────────────────
# GUARDRAILS_FILE=guardrails.json   # path to the guardrail policy
# ONCALL_LOG_DIR=logs               # where per-run JSONL traces are written
# VIZ_PORT=8000                     # live visualizer port
